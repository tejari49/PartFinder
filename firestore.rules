rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isStringField(data, field) {
      return data[field] is string;
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /parts/{partId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.sellerUid == request.auth.uid
        && isStringField(request.resource.data, 'category')
        && isStringField(request.resource.data, 'categorySlug')
        && isStringField(request.resource.data, 'brand')
        && isStringField(request.resource.data, 'model')
        && isStringField(request.resource.data, 'title')
        && isStringField(request.resource.data, 'description')
        && isStringField(request.resource.data, 'condition')
        && isStringField(request.resource.data, 'imageBase64')
        && isStringField(request.resource.data, 'sellerEmail')
        && isStringField(request.resource.data, 'sellerDisplayName')
        && request.resource.data.price is number;
      allow update, delete: if signedIn() && resource.data.sellerUid == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.sellerUid in request.resource.data.participantIds
        && request.resource.data.buyerUid in request.resource.data.participantIds
        && isStringField(request.resource.data, 'partId')
        && isStringField(request.resource.data, 'partTitle');
      allow update: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
          && request.resource.data.senderUid == request.auth.uid
          && isStringField(request.resource.data, 'text')
          && isStringField(request.resource.data, 'senderName');
        allow update, delete: if false;
      }
    }
  }
}
