rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function optionalString(data, field) {
      return !(field in data) || data[field] is string;
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function optionalNumber(data, field) {
      return !(field in data) || data[field] is number;
    }

    function optionalStringList(data, field) {
      return !(field in data) || data[field] is list;
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.name is string
        && request.resource.data.slug is string;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId)
        && optionalString(request.resource.data, 'displayName')
        && optionalString(request.resource.data, 'email')
        && optionalString(request.resource.data, 'whatsappNumber')
        && optionalString(request.resource.data, 'avatarBase64')
        && optionalString(request.resource.data, 'themePreference')
        && optionalBool(request.resource.data, 'chatEnabled');
      allow delete: if false;
    }

    match /favorites/{favoriteId} {
      allow read: if signedIn() && resource.data.userUid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.partId is string
        && request.resource.data.sellerUid is string;
      allow delete: if signedIn() && resource.data.userUid == request.auth.uid;
      allow update: if false;
    }

    match /parts/{partId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.category is string
        && request.resource.data.categorySlug is string
        && request.resource.data.brand is string
        && request.resource.data.model is string
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.condition is string
        && request.resource.data.sellerEmail is string
        && request.resource.data.sellerDisplayName is string
        && request.resource.data.imageBase64 is string
        && request.resource.data.price is number
        && optionalStringList(request.resource.data, 'imagesBase64')
        && optionalNumber(request.resource.data, 'imageCount')
        && optionalString(request.resource.data, 'location')
        && optionalBool(request.resource.data, 'shippingAvailable')
        && optionalBool(request.resource.data, 'pickupAvailable');
      allow update: if signedIn()
        && resource.data.sellerUid == request.auth.uid
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.category is string
        && request.resource.data.categorySlug is string
        && request.resource.data.brand is string
        && request.resource.data.model is string
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.condition is string
        && request.resource.data.sellerEmail is string
        && request.resource.data.sellerDisplayName is string
        && request.resource.data.imageBase64 is string
        && request.resource.data.price is number
        && optionalStringList(request.resource.data, 'imagesBase64')
        && optionalNumber(request.resource.data, 'imageCount')
        && optionalString(request.resource.data, 'location')
        && optionalBool(request.resource.data, 'shippingAvailable')
        && optionalBool(request.resource.data, 'pickupAvailable');
      allow delete: if signedIn() && resource.data.sellerUid == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.sellerUid in request.resource.data.participantIds
        && request.resource.data.buyerUid in request.resource.data.participantIds
        && request.resource.data.partId is string
        && request.resource.data.partTitle is string;
      allow update: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.senderName is string;
        allow update, delete: if false;
      }
    }
  }
}
